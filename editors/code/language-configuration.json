{
	"comments": {
		"blockComment": ["/*", "*/"],
		"lineComment": "//"
	},
	"brackets": [
		["(", ")"],
		["[", "]"],
		["{", "}"],
		["<", ">"]
	],
	"colorizedBracketPairs": [
		["{", "}"],
		["[", "]"],
		["(", ")"]
	],
	"autoClosingPairs": [
		{
			"open": "{",
			"close": "}"
		},
		{
			"open": "[",
			"close": "]"
		},
		{
			"open": "(",
			"close": ")"
		},
		{
			"open": "\"",
			"close": "\"",
			"notIn": ["string"]
		},
		{
			"open": "/*",
			"close": " */"
		}
	],
	"folding": {
		"markers": {
			"start": "^\\s*#ifdef\\b",
			"end": "^\\s*#endif\\b"
		}
	}
}
